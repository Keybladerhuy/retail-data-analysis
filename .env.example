# ─── Gmail email delivery ─────────────────────────────────────────────────────
# Gmail address the report is sent FROM
GMAIL_SENDER=you@gmail.com

# App Password generated at myaccount.google.com/apppasswords
# This is NOT your Gmail login password — it's a separate 16-character password
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email address the report is delivered TO
REPORT_RECIPIENT_EMAIL=client@example.com

# ─── Google Sheets live data ──────────────────────────────────────────────────
# Path to your Google service account JSON key file
# Download from Google Cloud Console → IAM & Admin → Service Accounts
GOOGLE_SHEETS_KEY_PATH=/path/to/service_account_key.json

# The ID from your client's Google Sheet URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SHEETS_TEMPLATE_ID=your_spreadsheet_id_here
